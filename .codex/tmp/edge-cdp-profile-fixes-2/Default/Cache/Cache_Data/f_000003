/* ===== QUIZ → DECISION TREE ===== */
const dtState = { step: 0, choices: [] };

function dtChoose(step, choice) {
  dtState.choices[step - 1] = choice;
  dtState.step = step;

  // Hide current step
  const currentStep = document.getElementById(`dtStep${step}`);
  currentStep.classList.remove('dt-step--active');
  currentStep.classList.add('dt-step--done');

  // Update progress
  updateDtProgress(step);

  if (step < 3) {
    setTimeout(() => {
      const nextStep = document.getElementById(`dtStep${step + 1}`);
      nextStep.classList.add('dt-step--active');
    }, 400);
  } else {
    setTimeout(() => showDtResult(), 500);
  }
}

function updateDtProgress(step) {
  const bar = document.getElementById('dtProgressBar');
  if (bar) bar.style.width = `${(step / 3) * 100}%`;

  for (let i = 1; i <= 3; i++) {
    const dot = document.querySelector(`.dt-step-dot[data-dt-step="${i}"]`);
    if (!dot) continue;
    if (i <= step) {
      dot.classList.add('dt-step-dot--done');
      const c = dtState.choices[i - 1];
      dot.classList.toggle('dt-step-dot--legal', c === 'legal');
      dot.classList.toggle('dt-step-dot--risk', c === 'risk');
      dot.classList.remove('dt-step-dot--active');
    }
    if (i === step + 1) {
      dot.classList.add('dt-step-dot--active');
    }
  }
}

function showDtResult() {
  const riskCount = dtState.choices.filter(c => c === 'risk').length;
  const resultEl = document.getElementById('dtResult');
  if (!resultEl) return;

  let profile, verdict, explanation, badgeClass;

  if (riskCount === 0) {
    profile = 'Cán Bộ Liêm Chính';
    verdict = 'CLEARED';
    badgeClass = 'dt-result--legal';
    explanation = 'Bạn đã tuân thủ đúng pháp luật ở mọi bước: trình cấp có thẩm quyền phê duyệt, tổ chức đấu thầu minh bạch, và sẵn sàng chịu trách nhiệm. Đây chính là tinh thần của Nhà nước pháp quyền XHCN — quyền lực phải được kiểm soát, minh bạch và phục vụ lợi ích công.';
  } else if (riskCount <= 2) {
    profile = 'Cảnh Báo Vi Phạm Pháp Quyền';
    verdict = 'WARNING';
    badgeClass = 'dt-result--warning';
    explanation = `Bạn đã chọn "đường tắt" ở ${riskCount} quyết định. Dù có thể xuất phát từ mong muốn hoàn thành công việc, nhưng trong Nhà nước pháp quyền XHCN, mục đích tốt không thể biện hộ cho sai thẩm quyền, thiếu minh bạch hay xung đột lợi ích. Mỗi vi phạm quy trình là một lỗ hổng để tham nhũng len lỏi.`;
  } else {
    profile = 'Ông Bình 2.0';
    verdict = 'GUILTY';
    badgeClass = 'dt-result--danger';
    explanation = 'Tất cả 3 quyết định đều lặp lại đúng sai lầm của ông Bình: vượt thẩm quyền, chỉ định thầu cho người thân, và che giấu khi bị phát hiện. Đây là hình mẫu điển hình của lạm quyền — khi quyền lực công bị cá nhân hóa, Nhà nước pháp quyền chỉ còn là khẩu hiệu.';
  }

  resultEl.innerHTML = `
    <div class="dt-profile ${badgeClass}">
      <div class="dt-profile-badge">${verdict}</div>
      <h3 class="dt-profile-name">${profile}</h3>
      <div class="dt-profile-choices">
        ${dtState.choices.map((c, i) => `
          <div class="dt-profile-choice ${c === 'legal' ? 'dt-profile-choice--legal' : 'dt-profile-choice--risk'}">
            <span>Bước ${i + 1}:</span> ${c === 'legal' ? 'Đúng pháp luật' : 'Vi phạm'}
          </div>
        `).join('')}
      </div>
      <p class="dt-profile-explanation">${explanation}</p>
      <button class="dt-reset-btn" onclick="dtReset()">
        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
        Thử lại từ đầu
      </button>
    </div>
  `;
  resultEl.classList.add('dt-result--active');
}

function dtReset() {
  dtState.step = 0;
  dtState.choices = [];

  // Reset progress
  const bar = document.getElementById('dtProgressBar');
  if (bar) bar.style.width = '0%';

  document.querySelectorAll('.dt-step-dot').forEach((dot, i) => {
    dot.className = 'dt-step-dot' + (i === 0 ? ' dt-step-dot--active' : '');
  });

  // Reset steps
  document.querySelectorAll('.dt-step').forEach((step, i) => {
    step.className = 'dt-step' + (i === 0 ? ' dt-step--active' : '');
  });

  // Reset result
  const result = document.getElementById('dtResult');
  if (result) {
    result.classList.remove('dt-result--active');
    result.innerHTML = '';
  }
}

/* ===== CORRUPTION FLOW ANIMATION ===== */
function initCorruptionFlow() {
  const pipeline = document.getElementById('corruptionFlow');
  if (!pipeline) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        pipeline.classList.add('cf-active');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

  observer.observe(pipeline);
}

/* ===== COUNT UP ===== */
function initCountUp() {
  const counters = document.querySelectorAll('.countup[data-target]');
  if (!counters.length) return;

  const animate = (el) => {
    const target = parseFloat(el.getAttribute('data-target') || '0');
    const duration = 1200;
    const start = performance.now();

    const step = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const current = target * progress;
      el.textContent = Number.isInteger(target) ? Math.round(current).toString() : current.toFixed(1);
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      animate(entry.target);
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.5 });

  counters.forEach((counter) => observer.observe(counter));
}

/* ===== HERO PARALLAX ===== */
function initParallaxBlueprint() {
  const hero = document.getElementById('hero');
  if (!hero) return;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduceMotion) return;

  const onScroll = () => {
    const rect = hero.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    if (rect.bottom < 0 || rect.top > viewportHeight) return;
    const progress = Math.max(0, Math.min(1, (viewportHeight - rect.top) / (viewportHeight + rect.height)));
    const shift = (progress - 0.5) * 24;
    hero.style.setProperty('--parallax-shift', `${shift.toFixed(2)}px`);
  };

  window.addEventListener('scroll', rafThrottle(onScroll), { passive: true });
  onScroll();
}

/* ===== FLOW LINE DRAWING ===== */
function initFlowLineDrawing() {
  const flowLines = document.querySelector('.dual-flow-lines');
  if (!flowLines) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      flowLines.classList.add('is-drawing');
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.35 });

  observer.observe(flowLines);
}

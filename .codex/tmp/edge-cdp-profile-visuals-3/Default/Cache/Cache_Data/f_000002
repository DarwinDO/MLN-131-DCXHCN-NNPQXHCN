  .principle-grid { grid-template-columns: 1fr; }

  .violation-cards {
    grid-template-columns: 1fr;
    max-width: 420px;
    margin: 0 auto;
  }

  .hero-illustration { display: none; }

  .theory-layout,
  .procurement-guard,
  .classification-strip {

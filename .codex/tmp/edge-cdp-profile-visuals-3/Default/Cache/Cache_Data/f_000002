  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  flex-shrink: 0;
}

.quiz-question-text {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.65;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 24px;
}

.quiz-option {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px 20px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: left;
  transition: all var(--duration-fast);
  position: relative;
}
.quiz-option::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: transparent;
  border-radius: var(--radius) 0 0 var(--radius);
  transition: background var(--duration-fast);
}

.quiz-option:hover {
  border-color: var(--navy-border);
  background: var(--navy-bg);
}
.quiz-option:hover::before { background: var(--navy); }

.quiz-option-letter {
  width: 28px;
  height: 28px;
  background: var(--navy);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.quiz-option-text {
  font-size: 0.88rem;
  line-height: 1.6;
  color: var(--body);
  padding-top: 3px;
}

/* Quiz states */
.quiz-option.selected { pointer-events: none; }
.quiz-option.correct {
  border-color: var(--success-border);
  background: var(--success-bg);
}
.quiz-option.correct::before { background: var(--success); }
.quiz-option.correct .quiz-option-letter { background: var(--success); }

.quiz-option.incorrect {
  border-color: var(--error-border);
  background: var(--error-bg);
  opacity: 0.7;
}
.quiz-option.incorrect::before { background: var(--error); }
.quiz-option.incorrect .quiz-option-letter { background: var(--error); }

.quiz-option.dimmed { opacity: 0.4; pointer-events: none; }

.quiz-feedback {
  padding: 24px 28px;
  border-radius: var(--radius);
  margin-bottom: 16px;
  display: none;
}
.quiz-feedback.show { display: block; }

.quiz-feedback.correct-feedback {
  background: var(--success-bg);
  border: 1px solid var(--success-border);
  border-left: 3px solid var(--success);
}
.quiz-feedback.incorrect-feedback {
  background: var(--error-bg);
  border: 1px solid var(--error-border);
  border-left: 3px solid var(--error);
}

.quiz-feedback h4 {
  font-size: 0.85rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 8px;
}
.quiz-feedback.correct-feedback h4 { color: var(--success); }
.quiz-feedback.incorrect-feedback h4 { color: var(--error); }

.quiz-feedback p {
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--body);
}

.quiz-reset-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--navy);
  border: 1px solid var(--navy-border);
  border-radius: 2px;
  transition: all var(--duration-fast);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.quiz-reset-btn:hover {
  background: var(--navy);
  color: var(--white);
}

/* ===== 20. LESSONS ===== */
.lessons-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--gap);
  max-width: 860px;
  margin: 0 auto;
}

.lesson-card {
  padding: 32px 28px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  position: relative;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s var(--ease-out);
}
.lesson-card.visible { opacity: 1; transform: translateY(0); }

/* Left accent */
.lesson-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--burgundy);
  border-radius: var(--radius) 0 0 var(--radius);
}

.lesson-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.lesson-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: var(--navy);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
  border-radius: 3px;
  margin-bottom: 16px;
}

.lesson-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 10px;
  line-height: 1.4;
}

.lesson-desc {
  font-size: 0.88rem;
  color: var(--body);
  line-height: 1.75;
}

/* ===== 21. DNA CITIZEN HUB ===== */
.dna-hub {
  position: relative;
  max-width: 900px;
  margin: 0 auto;
}

.dna-center {
  text-align: center;
  margin-bottom: 48px;
  opacity: 0;
  transform: scale(0.92);
  transition: all 0.8s var(--ease-out);
}
.dna-center.visible { opacity: 1; transform: scale(1); }

.dna-center-icon {
  width: 84px;
  height: 84px;
  background: var(--navy);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18px;
  color: var(--white);
  box-shadow:
    0 0 0 6px rgba(27, 42, 74, 0.08),
    0 0 0 12px rgba(27, 42, 74, 0.04),
    0 0 0 20px rgba(27, 42, 74, 0.02);
  animation: dnaPulse 4s ease-in-out infinite;
  position: relative;
}

/* Crosshair lines on center node */
.dna-center-icon::before,
.dna-center-icon::after {
  content: '';
  position: absolute;
  background: rgba(27, 42, 74, 0.08);
}
.dna-center-icon::before {
  width: 1px;
  height: 200%;
  left: 50%;
  top: -50%;
}
.dna-center-icon::after {
  width: 200%;
  height: 1px;
  top: 50%;
  left: -50%;
}

@keyframes dnaPulse {
  0%, 100% {
    box-shadow:
      0 0 0 6px rgba(27, 42, 74, 0.08),
      0 0 0 12px rgba(27, 42, 74, 0.04),
      0 0 0 20px rgba(27, 42, 74, 0.02);
  }
  50% {
    box-shadow:
      0 0 0 10px rgba(27, 42, 74, 0.10),
      0 0 0 20px rgba(27, 42, 74, 0.05),
      0 0 0 32px rgba(27, 42, 74, 0.02);
  }
}

.dna-center-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 900;
  color: var(--navy);
  margin-bottom: 4px;
}

.dna-center-sub {
  font-size: 0.85rem;
  color: var(--caption);
}

.dna-branches {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--gap);
}

.dna-branch {
  display: flex;
  gap: 16px;
  padding: 28px 24px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  position: relative;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s var(--ease-out);
}
.dna-branch.visible { opacity: 1; transform: translateY(0); }

/* Top-left notch per branch */
.dna-branch::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 24px;
  height: 3px;
}
.dna-branch:nth-child(1)::before { background: var(--burgundy); }
.dna-branch:nth-child(2)::before { background: var(--navy); }
.dna-branch:nth-child(3)::before { background: var(--gold); }
.dna-branch:nth-child(4)::before { background: var(--success); }

.dna-branch:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.dna-branch-icon {
  width: 44px;
  height: 44px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid;
}

.dna-branch:nth-child(1) .dna-branch-icon {
  background: var(--burgundy-bg);
  color: var(--burgundy);
  border-color: var(--burgundy-border);
}
.dna-branch:nth-child(2) .dna-branch-icon {
  background: var(--navy-bg);
  color: var(--navy);
  border-color: var(--navy-border);
}
.dna-branch:nth-child(3) .dna-branch-icon {
  background: var(--gold-bg);
  color: var(--gold);
  border-color: var(--gold-border);
}
.dna-branch:nth-child(4) .dna-branch-icon {
  background: var(--success-bg);
  color: var(--success);
  border-color: var(--success-border);
}

.dna-branch-content h3 {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 6px;
}

.dna-branch-content p {
  font-size: 0.85rem;
  color: var(--body);
  line-height: 1.7;
}

.dna-conclusion {
  text-align: center;
  margin-top: 40px;
  padding: 20px 32px;
  background: var(--burgundy-bg);
  border-left: 3px solid var(--burgundy);
  border-radius: 0 var(--radius) var(--radius) 0;
  font-size: 0.92rem;
  font-weight: 600;
  color: var(--burgundy);
  font-style: italic;
  line-height: 1.65;
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
}
.dna-conclusion.visible { opacity: 1; transform: translateY(0); }

/* ===== 22. AI PIPELINE ===== */
.ai-pipeline {
  max-width: 960px;
  margin: 0 auto 48px;
}

.ai-pipeline-track {
  display: flex;
  align-items: stretch;
  gap: 0;
  position: relative;
}

.ai-pipeline-node {
  flex: 1;
  text-align: center;
  padding: 28px 20px 24px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  position: relative;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s var(--ease-out);
}
.ai-pipeline-node.visible { opacity: 1; transform: translateY(0); }

/* Top accent per node position */
.ai-pipeline-node::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
}
.ai-pipeline-node:nth-child(1)::before { background: var(--navy); }
.ai-pipeline-node:nth-child(3)::before { background: var(--gold); }
.ai-pipeline-node:nth-child(5)::before { background: var(--burgundy); }
.ai-pipeline-node:nth-child(7)::before { background: var(--success); }

.ai-pipeline-node:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

.ai-pipeline-icon {
  width: 44px;
  height: 44px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 14px;
  border: 1px solid;
}

.ai-pipeline-icon--source {
  background: var(--navy-bg);
  color: var(--navy);
  border-color: var(--navy-border);
}
.ai-pipeline-icon--ai {
  background: var(--gold-bg);
  color: var(--gold);
  border-color: var(--gold-border);
}
.ai-pipeline-icon--review {
  background: var(--burgundy-bg);
  color: var(--burgundy);
  border-color: var(--burgundy-border);
}
.ai-pipeline-icon--output {
  background: var(--success-bg);
  color: var(--success);
  border-color: var(--success-border);
}

.ai-pipeline-node h4 {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 6px;
}

.ai-pipeline-node p {
  font-size: 0.78rem;
  color: var(--caption);
  line-height: 1.55;
}

.ai-pipeline-arrow {
  display: flex;
  align-items: center;
  padding: 0 8px;
  color: var(--muted);
  flex-shrink: 0;
  opacity: 0.5;
}

/* Tool tags */
.ai-tools-compact {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-bottom: 40px;
}

.ai-tool-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 2px;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--navy);
  transition: all var(--duration-fast);
}
.ai-tool-tag:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-sm);
}
.ai-tool-tag span {
  font-weight: 400;
  color: var(--caption);
  font-size: 0.72rem;
}

/* AI Integrity statement */
.ai-integrity {
  max-width: 720px;
  margin: 0 auto;
  padding: 28px 32px;
  background: var(--navy-bg);
  border: 1px solid var(--navy-border);
  border-left: 3px solid var(--navy);
  border-radius: 0 var(--radius) var(--radius) 0;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
}
.ai-integrity.visible { opacity: 1; transform: translateY(0); }

.ai-integrity-icon {
  width: 44px;
  height: 44px;
  background: var(--navy);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  flex-shrink: 0;
}

.ai-integrity h3 {
  font-size: 0.85rem;
  font-weight: 800;
  color: var(--navy);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 8px;
}

.ai-integrity p {
  font-size: 0.85rem;
  line-height: 1.7;
  color: var(--body);
}

/* ===== 23. REFERENCES ===== */
.references-list {
  max-width: 720px;
  margin: 0 auto;
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
}
.references-list.visible { opacity: 1; transform: translateY(0); }

.reference-item {
  display: flex;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--bp-line-strong);
}
.reference-item:last-child { border-bottom: none; }

.reference-number {
  font-size: 0.78rem;
  font-weight: 800;
  color: var(--burgundy);
  flex-shrink: 0;
  min-width: 28px;
}

.reference-text {
  font-size: 0.85rem;
  line-height: 1.65;
  color: var(--body);
}

/* ===== 24. FOOTER ===== */
.footer {
  background: var(--navy-dark);
  color: rgba(255, 255, 255, 0.5);
  padding: 48px 0 32px;
  position: relative;
}
/* Top border accent */
.footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--burgundy), var(--navy), var(--burgundy));
}

.footer-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 40px;
  margin-bottom: 32px;
}

.footer-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 4px;
  letter-spacing: 0.04em;
}

.footer-subtitle {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.02em;
}

.footer-info {
  display: flex;
  gap: 32px;
}

.footer-info-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.footer-label {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.3);
}

.footer-value {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20px;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.footer-note {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.3);
}

.footer-back-top {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  color: rgba(255, 255, 255, 0.4);
  transition: all var(--duration-fast);
}
.footer-back-top:hover {
  border-color: rgba(255, 255, 255, 0.3);
  color: var(--white);
  background: rgba(255, 255, 255, 0.06);
}

/* ===== 25. ANIMATION SYSTEM ===== */
/* Stagger delay utilities */
[data-animate] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
}

[data-animate].visible {
  opacity: 1;
  transform: translateY(0);
}

/* Stagger delays for children */
[data-stagger] > [data-animate]:nth-child(1) { transition-delay: 0s; }
[data-stagger] > [data-animate]:nth-child(2) { transition-delay: 0.08s; }
[data-stagger] > [data-animate]:nth-child(3) { transition-delay: 0.16s; }
[data-stagger] > [data-animate]:nth-child(4) { transition-delay: 0.24s; }
[data-stagger] > [data-animate]:nth-child(5) { transition-delay: 0.32s; }

/* Line draw for SVG connectors */
.line-draw path,
.line-draw line {
  stroke-dasharray: 200;
  stroke-dashoffset: 200;
  transition: stroke-dashoffset 1.2s var(--ease-out);
}
.line-draw.visible path,
.line-draw.visible line {
  stroke-dashoffset: 0;
}

/* Scroll progress animation */
@keyframes scrollHint {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(6px); }
}

/* ===== 26. RESPONSIVE ===== */

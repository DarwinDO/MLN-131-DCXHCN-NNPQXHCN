/* ============================================================
   HỒ SƠ VỤ VIỆC ÔNG BÌNH — VISUAL SYSTEM v3.0
   Governance-Tech · Blueprint · Academic Infographic
   ============================================================ */

/* ===== 01. DESIGN TOKENS ===== */
:root {
  /* — Primary Palette — */
  --burgundy: #6B1C23;
  --burgundy-dark: #4A1118;
  --burgundy-light: #8B2430;
  --burgundy-bg: rgba(107, 28, 35, 0.05);
  --burgundy-border: rgba(107, 28, 35, 0.18);

  --navy: #1B2A4A;
  --navy-dark: #0F1B33;
  --navy-light: #2A3F6B;
  --navy-bg: rgba(27, 42, 74, 0.05);
  --navy-border: rgba(27, 42, 74, 0.12);

  /* — Neutral Palette — */
  --ivory: #F5F3ED;
  --ivory-warm: #F0EDE5;
  --white: #FFFFFF;
  --ink: #1A1A2E;
  --body: #3D3D50;
  --caption: #6B7280;
  --muted: #8B9DAF;

  /* — Blueprint System — */
  --bp-line: rgba(27, 42, 74, 0.045);
  --bp-line-strong: rgba(27, 42, 74, 0.08);
  --bp-dot: rgba(27, 42, 74, 0.06);
  --bp-grid: 48px;

  /* — Accent (sparing) — */
  --gold: #9E7C0C;
  --gold-bg: rgba(158, 124, 12, 0.07);
  --gold-border: rgba(158, 124, 12, 0.18);
  --success: #2E6B32;
  --success-bg: rgba(46, 107, 50, 0.06);
  --success-border: rgba(46, 107, 50, 0.18);
  --error: #9B2226;
  --error-bg: rgba(155, 34, 38, 0.05);
  --error-border: rgba(155, 34, 38, 0.18);

  /* — Border & Shadow — */
  --border: rgba(27, 42, 74, 0.10);
  --border-strong: rgba(27, 42, 74, 0.18);
  --shadow-sm: 0 1px 3px rgba(15, 27, 51, 0.06);
  --shadow-md: 0 4px 16px rgba(15, 27, 51, 0.08);
  --shadow-lg: 0 8px 32px rgba(15, 27, 51, 0.10);
  --shadow-card: 0 2px 8px rgba(15, 27, 51, 0.05);

  /* — Typography — */
  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-display: 'Playfair Display', Georgia, serif;

  /* — Spacing — */
  --section-py: 100px;
  --container-max: 1200px;
  --gap: 24px;
  --radius: 6px;
  --radius-lg: 10px;

  /* — Transitions — */
  --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --duration: 0.5s;
  --duration-fast: 0.25s;
}

/* ===== 02. RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

body {
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.7;
  color: var(--body);
  background: var(--ivory);
  overflow-x: hidden;
}

img, svg { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }
ul, ol { list-style: none; }
strong { font-weight: 700; color: var(--ink); }

/* ===== 03. BLUEPRINT BACKGROUND SYSTEM ===== */
.bp-grid {
  background-image:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px);
  background-size: var(--bp-grid) var(--bp-grid);
}

.bp-dots {
  background-image: radial-gradient(circle, var(--bp-dot) 1px, transparent 1px);
  background-size: 24px 24px;
}

.bp-frame {
  position: relative;
}
.bp-frame::before {
  content: '';
  position: absolute;
  inset: 16px;
  border: 1px solid var(--bp-line-strong);
  border-radius: var(--radius);
  pointer-events: none;
  z-index: 0;
}

/* ===== 04. TYPOGRAPHY SCALE ===== */
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 5.5vw, 4rem);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--white);
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--navy);
}

.card-title {
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--navy);
}

.body-text {
  font-size: 0.92rem;
  line-height: 1.75;
  color: var(--body);
}

.caption-text {
  font-size: 0.8rem;
  line-height: 1.6;
  color: var(--caption);
  letter-spacing: 0.01em;
}

/* ===== 05. LAYOUT ===== */
.container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 32px;
}

.section {
  padding: var(--section-py) 0;
  position: relative;
  background-color: var(--white);
  background-image:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px);
  background-size: var(--bp-grid) var(--bp-grid);
}

.section--alt {
  background-color: var(--ivory);
  background-image:
    radial-gradient(circle, var(--bp-dot) 0.8px, transparent 0.8px);
  background-size: 24px 24px;
}

/* ===== 06. SCROLL PROGRESS ===== */
.scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--burgundy), var(--navy));
  z-index: 9999;
  transition: width 0.1s linear;
}

/* ===== 07. SECTION HEADER ===== */
.section-header {
  text-align: center;
  margin-bottom: 56px;
  position: relative;
  z-index: 1;
}

.section-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 32px;
  background: var(--navy);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  border-radius: 2px;
  margin-bottom: 20px;
  position: relative;
}
/* Notch on section number */
.section-number::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 1px;
  height: 6px;
  background: var(--navy-border);
}

.section-title {
  margin-bottom: 12px;
}

.section-subtitle {
  font-size: 0.95rem;
  color: var(--caption);
  max-width: 640px;
  margin: 0 auto;
  line-height: 1.65;
}

/* Section divider line */
.section-header::after {
  content: '';
  display: block;
  width: 48px;
  height: 2px;
  background: var(--burgundy);
  margin: 24px auto 0;
  border-radius: 1px;
}

/* ===== 08. NAVIGATION ===== */
.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(15, 27, 51, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  transition: background var(--duration-fast) var(--ease);
}

.nav-container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--white);
  font-weight: 800;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.nav-logo-icon {
  width: 22px;
  height: 22px;
  opacity: 0.7;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
}

.nav-link {
  padding: 6px 14px;
  font-size: 0.78rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.55);
  border-radius: 3px;
  transition: all var(--duration-fast) var(--ease);
  letter-spacing: 0.02em;
  position: relative;
}

.nav-link:hover {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.06);
}

.nav-link.active {
  color: var(--white);
  background: rgba(107, 28, 35, 0.5);
}

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 6px;
}

.nav-toggle span {
  width: 20px;
  height: 1.5px;
  background: var(--white);
  border-radius: 1px;
  transition: var(--duration-fast);
}

/* ===== 09. HERO ===== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 120px 32px 80px;
  background: linear-gradient(145deg, var(--navy-dark) 0%, var(--navy) 50%, #1E3355 100%);
  overflow: hidden;
}

.hero-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: var(--bp-grid) var(--bp-grid);
  pointer-events: none;
}

.hero-grid-bg,
.hero-decoration {
  transform: translateY(var(--parallax-shift, 0px));
}

.hero-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.4;
}

.hero-content {
  max-width: var(--container-max);
  margin: 0 auto;
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 680px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: rgba(107, 28, 35, 0.3);
  border: 1px solid rgba(107, 28, 35, 0.4);
  border-radius: 2px;
  color: rgba(255, 255, 255, 0.8);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 28px;
}

.hero-title {
  margin-bottom: 16px;
}

.hero-title-accent {
  display: block;
  color: #E8B4B4;
  font-size: 1.15em;
}

.hero-subtitle {
  font-family: var(--font-body);
  font-size: 1.15rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.hero-desc {
  font-size: 1rem;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.7;
  margin-bottom: 36px;
  max-width: 540px;
}

.hero-casefile {
  margin-bottom: 28px;
  max-width: 620px;
  padding: 16px;
  border: 1px solid rgba(255, 255, 255, 0.16);
  background: rgba(7, 13, 27, 0.55);
  border-radius: 6px;
}

.hero-casefile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.hero-casefile-tag {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  color: #f0b4b4;
}

.hero-casefile-code {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.06em;
}

.hero-casefile-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 12px;
}

.hero-case-item {
  padding: 10px;
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
}

.hero-case-item p {
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.62);
  margin-bottom: 6px;
}

.hero-case-item strong {
  display: block;
  font-size: 1.2rem;
  color: #fff;
}

.hero-case-item span {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.6);
}

.hero-case-item--warn strong {
  color: #f4a0a0;
  font-size: 0.88rem;
}

.hero-leak span {
  display: block;
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 6px;
}

.hero-leak-track {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.hero-leak-fill {
  height: 100%;
  background: linear-gradient(90deg, #b33a3f, #e88b8b);
}

/* Hero tags */
.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 40px;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 7px 14px;
  border-radius: 2px;
  font-size: 0.78rem;
  font-weight: 600;
  border: 1px solid;
}

.hero-tag--red {
  background: rgba(107, 28, 35, 0.25);
  border-color: rgba(107, 28, 35, 0.4);
  color: #F0B4B4;
}
.hero-tag--amber {
  background: rgba(158, 124, 12, 0.2);
  border-color: rgba(158, 124, 12, 0.35);
  color: #E8D48A;
}
.hero-tag--navy {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.7);
}

/* Hero CTAs */
.hero-ctas {
  display: flex;
  gap: 14px;
  margin-bottom: 48px;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  font-size: 0.85rem;
  font-weight: 700;
  border-radius: 3px;
  transition: all var(--duration-fast) var(--ease);
  letter-spacing: 0.02em;
}

.btn-primary {
  background: var(--burgundy);
  color: var(--white);
  border: 1px solid var(--burgundy-light);
}
.btn-primary:hover {
  background: var(--burgundy-light);
  box-shadow: 0 4px 20px rgba(107, 28, 35, 0.3);
  transform: translateY(-1px);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.12);
  color: var(--white);
}

/* Hero meta */
.hero-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.3);
}
.hero-meta-dot { opacity: 0.4; }

/* Hero illustration */
.hero-illustration {
  position: absolute;
  right: 5%;
  top: 50%;
  transform: translateY(-50%);
  width: 520px;
  height: 420px;
  z-index: 1;
}

.hero-svg { width: 100%; height: 100%; }

/* Hero decoration */
.hero-decoration {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.hero-deco-circle {
  position: absolute;
  top: 15%;
  right: 10%;
  width: 300px;
  height: 300px;
  border: 1px solid rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}

.hero-deco-line {
  position: absolute;
  background: rgba(255, 255, 255, 0.03);
}
.hero-deco-line--1 {
  width: 1px;
  height: 200px;
  top: 20%;
  right: 30%;
}
.hero-deco-line--2 {
  width: 160px;
  height: 1px;
  bottom: 25%;
  right: 15%;
}

.hero-deco-square {
  position: absolute;
  bottom: 20%;
  right: 25%;
  width: 60px;
  height: 60px;
  border: 1px solid rgba(255, 255, 255, 0.04);
  transform: rotate(45deg);
}

/* ===== 10. TIMELINE ===== */
.timeline {
  position: relative;
  max-width: 720px;
  margin: 0 auto 48px;
  padding-left: 48px;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 18px;
  top: 8px;
  bottom: 8px;
  width: 2px;
  background: repeating-linear-gradient(
    to bottom,
    var(--navy-border) 0px,
    var(--navy-border) 6px,
    transparent 6px,
    transparent 12px
  );
}

.timeline-item {
  position: relative;
  padding: 0 0 40px 32px;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s var(--ease-out);
}

.timeline-item.visible {
  opacity: 1;
  transform: translateY(0);
}

.timeline-marker {
  position: absolute;
  left: -35px;
  top: 2px;
}

.timeline-step {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: var(--navy);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
  border-radius: 2px;
  border: 2px solid var(--ivory);
  position: relative;
  z-index: 1;
}

.timeline-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 6px;
}

.timeline-desc {
  font-size: 0.88rem;
  color: var(--body);
  line-height: 1.7;
}

/* ===== 11. CORE ISSUE BOX ===== */
.core-issue-box {
  max-width: 720px;
  margin: 0 auto;
  padding: 28px 32px;
  background: var(--burgundy-bg);
  border: 1px solid var(--burgundy-border);
  border-left: 3px solid var(--burgundy);
  border-radius: 0 var(--radius) var(--radius) 0;
  position: relative;
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
}
.core-issue-box.visible { opacity: 1; transform: translateY(0); }

.core-issue-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  color: var(--burgundy);
}

.core-issue-header h3 {
  font-size: 0.95rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--burgundy);
}

.core-issue-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.core-issue-list li {
  display: flex;
  gap: 10px;
  font-size: 0.88rem;
  line-height: 1.65;
  color: var(--body);
}

.evidence-board {
  max-width: 900px;
  margin: 0 auto 36px;
  padding: 24px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: linear-gradient(180deg, #f8f8f8, #f2efe8);
}

.evidence-title {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--navy);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 16px;
}

.evidence-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}

.evidence-card {
  padding: 16px;
  background: #fff;
  border: 1px solid var(--border);
  border-left: 3px solid var(--burgundy);
  border-radius: 4px;
}

.evidence-label {
  display: inline-block;
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  font-weight: 800;
  color: var(--burgundy);
  margin-bottom: 6px;
}

.evidence-card h4 {
  font-size: 0.92rem;
  color: var(--navy);
  margin-bottom: 6px;
}

.evidence-card p {
  font-size: 0.82rem;
  color: var(--body);
  line-height: 1.6;
}

.core-issue-icon {
  color: var(--burgundy);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ===== 12. CARD SYSTEM — PANEL LANGUAGE ===== */
/* Base card with top-left notch accent */
.panel-card {
  position: relative;
  padding: 32px 28px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  transition: all var(--duration) var(--ease);
  overflow: hidden;
}

.panel-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 36px;
  height: 3px;
  background: var(--burgundy);
}

.panel-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

/* Card with inner frame line */
.panel-card--framed::after {
  content: '';
  position: absolute;
  inset: 8px;
  border: 1px solid var(--bp-line-strong);
  border-radius: 3px;
  pointer-events: none;
}

/* ===== 13. VIOLATION CARDS ===== */
.violation-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--gap);
  max-width: 960px;
  margin: 0 auto;
}

.violation-card {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  opacity: 0;
  transform: translateY(24px);
  transition: all 0.6s var(--ease-out);
}
.violation-card.visible { opacity: 1; transform: translateY(0); }

.violation-card-front {
  padding: 36px 28px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: center;
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all var(--duration) var(--ease);
}

/* Top notch accent per card */
.violation-card-front::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
}
#violationA .violation-card-front::before { background: var(--burgundy); }
#violationB .violation-card-front::before { background: var(--gold); }
#violationC .violation-card-front::before { background: var(--navy); }

/* Inner frame */
.violation-card-front::after {
  content: '';
  position: absolute;
  inset: 10px;
  border: 1px dashed var(--bp-line-strong);
  border-radius: 3px;
  pointer-events: none;
  opacity: 0;
  transition: opacity var(--duration-fast);
}

.violation-card:hover .violation-card-front {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

.violation-card:hover .violation-card-front::after {
  opacity: 1;
}

.violation-card-stamp {
  position: absolute;
  top: 10px;
  right: 10px;
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 8px;
  border-radius: 4px;
  border: 2px solid;
  opacity: 0;
  transform: scale(0.82) rotate(-10deg);
  z-index: 2;
  pointer-events: none;
}

.violation-card.visible .violation-card-stamp {
  animation: cardStampIn 520ms var(--ease-out) forwards;
}

.violation-card-stamp--danger {
  color: #922226;
  border-color: rgba(146, 34, 38, 0.55);
  background: rgba(146, 34, 38, 0.08);
}

.violation-card-stamp--warning {
  color: #7a5a0a;
  border-color: rgba(122, 90, 10, 0.5);
  background: rgba(122, 90, 10, 0.08);
}

.violation-card-stamp--loss {
  color: #6b1c23;
  border-color: rgba(107, 28, 35, 0.5);
  background: rgba(107, 28, 35, 0.08);
}

@keyframes cardStampIn {
  0% {
    opacity: 0;
    transform: scale(0.82) rotate(-10deg);
  }
  70% {
    opacity: 1;
    transform: scale(1.06) rotate(-3deg);
  }
  100% {
    opacity: 1;
    transform: scale(1) rotate(-5deg);
  }
}

.violation-icon {
  width: 56px;
  height: 56px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  border: 1px solid;
}

.violation-icon--red {
  background: var(--burgundy-bg);
  color: var(--burgundy);
  border-color: var(--burgundy-border);
}
.violation-icon--amber {
  background: var(--gold-bg);
  color: var(--gold);
  border-color: var(--gold-border);
}
.violation-icon--navy {
  background: var(--navy-bg);
  color: var(--navy);
  border-color: var(--navy-border);
}

.violation-card-title {
  font-size: 1rem;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.violation-card-brief {
  font-size: 0.85rem;
  color: var(--caption);
  line-height: 1.6;
  margin-bottom: 20px;
  flex: 1;
}

.violation-card-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--burgundy);
  border: 1px solid var(--burgundy-border);
  border-radius: 2px;
  transition: all var(--duration-fast);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.violation-card-btn:hover {
  background: var(--burgundy);
  color: var(--white);
  border-color: var(--burgundy);
}

/* ===== 14. MODAL ===== */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 27, 51, 0.7);
  backdrop-filter: blur(6px);
  z-index: 10000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.modal-overlay.active { display: flex; }

.modal-container {
  background: var(--white);
  border-radius: var(--radius-lg);
  max-width: 640px;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  padding: 40px;
  position: relative;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-lg);
}

.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 3px;
  color: var(--caption);
  transition: all var(--duration-fast);
}
.modal-close:hover {
  background: var(--burgundy-bg);
  color: var(--burgundy);
}

.modal-body h3 {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 20px;
}

.modal-body h4 {
  font-size: 0.85rem;
  font-weight: 800;
  color: var(--burgundy);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin: 20px 0 8px;
}

.modal-body p, .modal-body li {
  font-size: 0.88rem;
  line-height: 1.75;
  color: var(--body);
  margin-bottom: 8px;
}

.modal-body ul { padding-left: 16px; }
.modal-body ul li::before {
  content: '▸ ';
  color: var(--burgundy);
  font-weight: 700;
}

/* ===== 15. PRINCIPLE MATRIX ===== */
.principle-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  max-width: 860px;
  margin: 0 auto;
}

.principle-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  cursor: pointer;
  transition: all var(--duration) var(--ease);
  position: relative;
  opacity: 0;
  transform: translateY(16px);
}
.principle-card.visible { opacity: 1; transform: translateY(0); }

/* Left accent bar */
.principle-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--navy);
  transition: background var(--duration-fast);
}

.principle-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
}

.principle-card.active::before {
  background: var(--burgundy);
}
.principle-card.active {
  border-color: var(--burgundy-border);
  box-shadow: var(--shadow-md);
}

.principle-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 24px 20px 20px;
}

.principle-number {
  width: 36px;
  height: 36px;
  background: var(--navy);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background var(--duration-fast);
}

.principle-card.active .principle-number {
  background: var(--burgundy);
}

.principle-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--navy);
  flex: 1;
}

.principle-chevron {
  color: var(--caption);
  transition: transform var(--duration-fast);
  flex-shrink: 0;
}
.principle-card.active .principle-chevron {
  transform: rotate(180deg);
  color: var(--burgundy);
}

.principle-card-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s var(--ease);
}

.principle-card.active .principle-card-detail {
  max-height: 600px;
}

.principle-explain,
.principle-case,
.principle-why {
  padding: 0 24px 16px 20px;
  border-top: 1px solid var(--bp-line-strong);
  margin-left: 20px;
  margin-right: 20px;
  padding-top: 16px;
}

.principle-explain h4,
.principle-case h4,
.principle-why h4 {
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}

.principle-explain h4 { color: var(--navy); }
.principle-case h4 { color: var(--burgundy); }
.principle-why h4 { color: var(--gold); }

.principle-explain p,
.principle-case p,
.principle-why p {
  font-size: 0.88rem;
  line-height: 1.75;
  color: var(--body);
}

.democracy-gates {
  max-width: 1040px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  gap: 12px;
  align-items: stretch;
}

.democracy-gate {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 18px;
  position: relative;
  overflow: hidden;
}

.democracy-gate::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 30px;
  height: 3px;
}

.democracy-gate--know::before { background: var(--navy); }
.democracy-gate--discuss::before { background: var(--gold); }
.democracy-gate--check::before { background: var(--burgundy); }

.democracy-gate-icon {
  width: 42px;
  height: 42px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  border: 1px solid;
}

.democracy-gate--know .democracy-gate-icon {
  background: var(--navy-bg);
  color: var(--navy);
  border-color: var(--navy-border);
}

.democracy-gate--discuss .democracy-gate-icon {
  background: var(--gold-bg);
  color: var(--gold);
  border-color: var(--gold-border);
}

.democracy-gate--check .democracy-gate-icon {
  background: var(--burgundy-bg);
  color: var(--burgundy);
  border-color: var(--burgundy-border);
}

.democracy-gate h3 {
  font-size: 0.96rem;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.democracy-gate p {
  font-size: 0.84rem;
  line-height: 1.65;
  color: var(--body);
}

.democracy-gate-case {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px dashed var(--bp-line-strong);
  color: var(--caption);
}

.democracy-gate-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--navy);
  font-size: 1.2rem;
  opacity: 0.45;
}

.democracy-conclusion {
  max-width: 860px;
  margin: 18px auto 0;
  padding: 18px 22px;
  border-left: 3px solid var(--burgundy);
  background: var(--burgundy-bg);
  border-radius: 0 var(--radius) var(--radius) 0;
  font-size: 0.92rem;
  line-height: 1.6;
  font-weight: 600;
  color: var(--burgundy);
}

/* ===== 16. THEORY BRIDGE FROM SLIDES ===== */
.theory-layout {
  max-width: 560px;
  margin: 0 auto 32px;
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--gap);
  align-items: stretch;
}

.theory-compass,
.feature-tile,
.democracy-law-loop,
.procurement-guard,
.classification-strip {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

.theory-compass {
  position: relative;
  min-height: 394px;
  padding: 24px;
  overflow: hidden;
  display: grid;
  grid-template-rows: minmax(220px, 1fr) auto;
  gap: 16px;
  background-image:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px);
  background-size: 32px 32px;
}

.compass-stage {
  position: relative;
  min-height: 240px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compass-ring {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.compass-ring--outer {
  width: 250px;
  height: 250px;
  border: 2px dashed rgba(107, 28, 35, 0.35);
}

.compass-ring--middle {
  width: 196px;
  height: 196px;
  border: 18px solid var(--navy);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.16);
}

.compass-core {
  position: relative;
  z-index: 2;
  width: 140px;
  height: 140px;
  border-radius: 999px;
  background: var(--burgundy);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 800;
  line-height: 1.22;
}

.compass-note {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--bp-line-strong);
  border-left: 3px solid var(--navy);
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(4px);
}

.compass-legend {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}

.compass-note--party { border-left-color: var(--burgundy); }
.compass-note--law { border-left-color: var(--navy); }
.compass-note--people { border-left-color: var(--gold); }

.compass-note strong {
  display: block;
  margin-bottom: 4px;
  color: var(--navy);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.compass-note span {
  display: block;
  color: var(--body);
  font-size: 0.78rem;
  line-height: 1.55;
}

.feature-blueprint {
  max-width: 1100px;
  margin: 0 auto 36px;
  display: grid;
  grid-template-columns: repeat(8, minmax(72px, 1fr));
  gap: 10px;
}

.feature-tile {
  --pillar-h: 150px;
  --pillar-color: var(--navy);
  position: relative;
  min-height: 400px;
  padding: calc(var(--pillar-h) + 104px) 8px 12px;
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
  overflow: visible;
  text-align: center;
  background:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px),
    var(--white);
  background-size: 24px 24px;
}
.feature-tile.visible { opacity: 1; transform: translateY(0); }

.feature-tile::before {
  content: '';
  position: absolute;
  top: 62px;
  left: 50%;
  width: 42px;
  height: var(--pillar-h);
  transform: translateX(-50%) skewY(-4deg);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.72), transparent 42%),
    repeating-linear-gradient(90deg, transparent 0 6px, rgba(255,255,255,0.18) 6px 8px),
    var(--pillar-color);
  border: 1px solid rgba(16, 31, 56, 0.35);
  box-shadow: 8px 10px 0 rgba(16, 31, 56, 0.1);
}

.feature-tile::after {
  content: '';
  position: absolute;
  top: 42px;
  left: 50%;
  width: 74px;
  height: 28px;
  transform: translateX(-50%) skewX(-18deg);
  background:
    linear-gradient(135deg, rgba(255,255,255,0.82), rgba(255,255,255,0.28)),
    var(--white);
  border: 1px solid rgba(16, 31, 56, 0.38);
  box-shadow: 8px 8px 0 rgba(107, 28, 35, 0.12);
}

.feature-tile:nth-child(1) { --pillar-h: 148px; }
.feature-tile:nth-child(2) { --pillar-h: 160px; }
.feature-tile:nth-child(3) { --pillar-h: 172px; --pillar-color: var(--gold); }
.feature-tile:nth-child(4) { --pillar-h: 184px; }
.feature-tile:nth-child(5),
.feature-tile--accent { --pillar-h: 204px; --pillar-color: var(--burgundy); }
.feature-tile:nth-child(6) { --pillar-h: 176px; }
.feature-tile:nth-child(7) { --pillar-h: 166px; }
.feature-tile:nth-child(8) { --pillar-h: 154px; }

.feature-tile span {
  position: absolute;
  left: 50%;
  top: calc(var(--pillar-h) + 56px);
  z-index: 2;
  display: inline-flex;
  width: 32px;
  height: 28px;
  align-items: center;
  justify-content: center;
  transform: translateX(-50%);
  border-radius: 3px;
  background: var(--pillar-color);
  color: var(--white);
  font-size: 0.72rem;
  font-weight: 800;
}

.feature-tile--accent span {
  background: var(--burgundy);
  color: var(--white);
}

.feature-tile h3 {
  margin: 0 0 8px;
  color: var(--navy);
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  line-height: 1.35;
}

.feature-tile p {
  display: none;
}

.feature-blueprint--pillars {
  position: relative;
  padding: 28px 18px 20px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  background:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px),
    radial-gradient(circle at 50% 20%, rgba(107, 28, 35, 0.08), transparent 34%),
    var(--white);
  background-size: 28px 28px, 28px 28px, auto, auto;
}

.feature-blueprint--pillars::before {
  content: '8 đặc trưng cốt lõi';
  position: absolute;
  top: 12px;
  left: 18px;
  color: var(--caption);
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.feature-blueprint--pillars .feature-tile {
  border: 0;
  box-shadow: none;
  background: transparent;
}

.democracy-law-loop {
  max-width: 1060px;
  margin: 0 auto;
  padding: 22px;
  display: grid;
  grid-template-columns: 1fr 170px 1fr;
  gap: 14px;
  align-items: stretch;
  position: relative;
}

.loop-panel {
  padding: 22px 20px;
  border: 1px solid var(--bp-line-strong);
  border-radius: 4px;
}

.loop-panel h3 {
  margin-bottom: 8px;
  font-family: var(--font-display);
  font-size: 1.05rem;
  color: var(--navy);
}

.loop-panel p {
  color: var(--body);
  font-size: 0.86rem;
  line-height: 1.65;
}

.loop-panel--democracy {
  background: var(--burgundy-bg);
  border-color: var(--burgundy-border);
}

.loop-panel--law {
  background: var(--navy-bg);
  border-color: var(--navy-border);
}

.loop-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  text-align: center;
  color: var(--caption);
  border-left: 1px dashed var(--bp-line-strong);
  border-right: 1px dashed var(--bp-line-strong);
}

.loop-connector strong {
  color: var(--burgundy);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.76rem;
}

.loop-connector em {
  font-size: 0.76rem;
  font-style: normal;
}

.loop-summary {
  grid-column: 1 / -1;
  padding: 16px 18px;
  border-left: 3px solid var(--gold);
  background: var(--gold-bg);
  color: var(--body);
  line-height: 1.65;
  font-size: 0.88rem;
}

.loop-summary strong { color: var(--navy); }

.democracy-law-loop--infinity {
  overflow: hidden;
  grid-template-columns: minmax(220px, 1fr) minmax(230px, 0.8fr) minmax(220px, 1fr);
  padding: 28px;
  background:
    linear-gradient(var(--bp-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--bp-line) 1px, transparent 1px),
    var(--white);
  background-size: 30px 30px;
}

.democracy-law-loop--infinity .loop-panel {
  position: relative;
  z-index: 2;
  min-height: 150px;
  border-width: 2px;
  box-shadow: 8px 8px 0 rgba(16, 31, 56, 0.08);
}

.democracy-law-loop--infinity .loop-panel::before {
  content: '';
  position: absolute;
  top: 18px;
  bottom: 18px;
  width: 3px;
  background: currentColor;
  opacity: 0.8;
}

.democracy-law-loop--infinity .loop-panel--democracy::before { right: -18px; }
.democracy-law-loop--infinity .loop-panel--law::before { left: -18px; }

.democracy-law-loop--infinity .loop-connector {
  position: relative;
  min-height: 176px;
  border: 0;
  isolation: isolate;
}

.democracy-law-loop--infinity .loop-connector::before {
  content: '∞';
  position: absolute;
  inset: 50% auto auto 50%;
  transform: translate(-50%, -50%);
  z-index: -1;
  color: rgba(16, 31, 56, 0.16);
  font-family: Georgia, serif;
  font-size: 11rem;
  font-weight: 800;
  line-height: 1;
}

.democracy-law-loop--infinity .loop-connector::after {
  content: '';
  position: absolute;
  inset: 44px 20px;
  border-top: 9px solid var(--burgundy);
  border-bottom: 9px solid var(--navy);
  border-radius: 999px;
  opacity: 0.86;
}

.democracy-law-loop--infinity .loop-connector span,
.democracy-law-loop--infinity .loop-connector strong,
.democracy-law-loop--infinity .loop-connector em {
  position: relative;
  z-index: 1;
  padding: 2px 8px;
  background: var(--white);
}

.democracy-law-loop--infinity .loop-summary {
  border-left: 0;
  border-top: 3px solid var(--gold);
  box-shadow: inset 0 0 0 1px rgba(193, 154, 91, 0.25);
}

/* ===== 16. ROADMAP (BỐI CẢNH LỚN) ===== */
.roadmap-grid {
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 0;
  max-width: 960px;
  margin: 0 auto;
}

.roadmap-card {
  flex: 1;
  padding: 36px 24px 32px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: center;
  position: relative;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s var(--ease-out);
}

.roadmap-card.visible { opacity: 1; transform: translateY(0); }

/* Top notch */
.roadmap-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24px;
  width: 32px;
  height: 3px;
  border-radius: 0 0 2px 2px;
}

/* ===== 17. BREAKTHROUGH (3 ĐỘT PHÁ) ===== */
.breakthrough-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--gap);
  margin-bottom: 40px;
}

.breakthrough-card {
  padding: 40px 28px 36px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: center;
  position: relative;
  opacity: 0;
  transform: translateY(24px);
  transition: all 0.6s var(--ease-out);
}
.breakthrough-card.visible { opacity: 1; transform: translateY(0); }

/* Top accent bar */
.breakthrough-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--burgundy), var(--burgundy-light));
}

/* Inner frame */
.breakthrough-card::after {
  content: '';
  position: absolute;
  inset: 10px;
  border: 1px dashed var(--bp-line-strong);
  border-radius: 3px;
  pointer-events: none;
  opacity: 0;
  transition: opacity var(--duration-fast);
}

.breakthrough-card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}
.breakthrough-card:hover::after { opacity: 1; }

.breakthrough-num {
  width: 48px;
  height: 48px;
  background: var(--navy);
  color: var(--white);
  font-weight: 900;
  font-size: 1.2rem;
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 22px;
  position: relative;
}
/* Corner notch on number */
.breakthrough-num::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  width: 1px;
  height: 8px;
  background: var(--navy-border);
}

.breakthrough-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.breakthrough-desc {
  font-size: 0.88rem;
  color: var(--body);
  line-height: 1.7;
}

.breakthrough-conclusion {
  max-width: 800px;
  margin: 0 auto;
  padding: 24px 32px;
  background: var(--navy);
  border-radius: var(--radius);
  color: rgba(255,255,255,0.85);
  font-size: 0.92rem;
  line-height: 1.75;
  text-align: center;
  font-weight: 500;
  border-left: 3px solid var(--burgundy);
  opacity: 0;
  transform: translateY(16px);
  transition: all 0.6s var(--ease-out);
}
.breakthrough-conclusion.visible { opacity: 1; transform: translateY(0); }


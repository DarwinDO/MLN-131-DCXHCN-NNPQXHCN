    width: 126px;
    height: 126px;
    font-size: 1.08rem;
  }

  .feature-blueprint,
  .democracy-law-loop,
  .procurement-grid {
    grid-template-columns: 1fr;
  }

  .feature-blueprint--pillars {
    grid-template-columns: repeat(2, minmax(120px, 1fr));
    padding: 26px 14px 18px;
  }

  .democracy-law-loop--infinity .loop-connector {
    min-height: 120px;
    border-top: 0;
    border-bottom: 0;
  }

  .democracy-law-loop--infinity .loop-connector::before {
    font-size: 7.5rem;
  }

  .democracy-law-loop--infinity .loop-connector::after {
    inset: 32px 24px;
    border-top-width: 7px;
    border-bottom-width: 7px;
  }

  .democracy-law-loop--infinity .loop-panel::before {
    display: none;
  }

  .loop-connector {
    min-height: 82px;
    border-left: none;
    border-right: none;
    border-top: 1px dashed var(--bp-line-strong);
    border-bottom: 1px dashed var(--bp-line-strong);
  }

  .procurement-visual {
    min-height: auto;
    padding: 18px;
    display: grid;
    gap: 12px;
  }

  .procurement-screen,
  .procurement-rail,
  .procurement-lock {
    position: relative;
    inset: auto;
    width: auto;
    height: auto;
    min-height: auto;
    transform: none;
  }

  .procurement-rail {
    padding: 12px 12px 12px 58px;
  }

  .procurement-rail::before,
  .procurement-rail::after,
  .procurement-lock::before {
    display: none;
  }

  .procurement-lock {
    display: none;
  }

  .evidence-grid {
    grid-template-columns: 1fr;
  }

  .moneyflow-line {
    grid-template-columns: 1fr;
  }

  .moneyflow-arrow {
    transform: rotate(90deg);
    margin: -6px 0;
  }

  .justice-balance {
    grid-template-columns: 1fr;
  }

  .dual-flow {
    grid-template-columns: 1fr;
  }

  .flow-vs {
    width: 100%;
    border-radius: 4px;
    height: 36px;
  }

  .dual-flow-lines {
    display: none;
  }

  .justice-pivot {
    width: 100%;
    height: 70px;
  }

  .justice-beam {
    width: 100%;
    height: 3px;
  }

  .footer-content {
    flex-direction: column;
    gap: 24px;
  }
  .footer-info {
    flex-direction: column;
    gap: 16px;
  }
}

@media (max-width: 480px) {
  :root { --section-py: 52px; }

  .hero-title { font-size: 2rem; }
  .hero-badge { font-size: 0.65rem; }
  .hero-tag { font-size: 0.7rem; padding: 5px 10px; }
  .btn { padding: 10px 18px; font-size: 0.8rem; }

  .section-number { width: 44px; height: 28px; font-size: 0.65rem; }

  .procurement-guard,
  .classification-strip {
    padding: 20px;
  }

  .compass-note {
    width: 100%;
    padding: 9px;
  }

  .compass-note span {
    font-size: 0.72rem;
  }

  .feature-tile {
    min-height: auto;
  }

  .feature-blueprint--pillars .feature-tile {
    min-height: 330px;
  }

  .violation-card-front { padding: 28px 20px; }
  .lesson-card { padding: 24px 20px; }
  .dna-branch { padding: 24px 20px; }
}

}

.dual-flow-lines.is-drawing path:nth-child(2) { animation-delay: 70ms; }
.dual-flow-lines.is-drawing path:nth-child(3) { animation-delay: 140ms; }
.dual-flow-lines.is-drawing path:nth-child(4) { animation-delay: 210ms; }
.dual-flow-lines.is-drawing path:nth-child(5) { animation-delay: 280ms; }
.dual-flow-lines.is-drawing path:nth-child(6) { animation-delay: 340ms; }
.dual-flow-lines.is-drawing path:nth-child(7) { animation-delay: 400ms; }
.dual-flow-lines.is-drawing path:nth-child(8) { animation-delay: 460ms; }
.dual-flow-lines.is-drawing path:nth-child(9) { animation-delay: 520ms; }
.dual-flow-lines.is-drawing path:nth-child(10) { animation-delay: 580ms; }

@keyframes drawPath {
  from { stroke-dashoffset: 180; }
  to { stroke-dashoffset: 0; }
}

/* ===== 19. QUIZ ===== */
.quiz-container {
  max-width: 720px;
  margin: 0 auto;
  position: relative;
}

.quiz-verdict-overlay {
  position: absolute;
  inset: 8% 6%;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(10, 18, 34, 0.18);
  z-index: 8;
  border-radius: 10px;
  pointer-events: none;
  border: 1px solid rgba(15, 27, 51, 0.08);
  backdrop-filter: blur(1px);
}

.quiz-verdict-overlay.show {
  display: flex;
}

.quiz-verdict-pop {
  width: min(360px, 88%);
  background: #fff;
  border: 2px solid rgba(107, 28, 35, 0.35);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 16px 36px rgba(10, 18, 34, 0.35);
  transform: translateY(24px) scale(0.84);
  opacity: 0;
}

.quiz-verdict-overlay.show .quiz-verdict-pop {
  animation: verdictPopIn 720ms cubic-bezier(0.22, 1.35, 0.34, 1) forwards;
}

.quiz-verdict-pop img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
}

.quiz-verdict-stamp {
  position: absolute;
  top: 16px;
  right: 14px;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  padding: 8px 10px;
  border-radius: 4px;
  color: #8f1d21;
  background: rgba(255, 236, 236, 0.92);
  border: 2px solid rgba(143, 29, 33, 0.65);
  transform: rotate(-10deg) scale(0.84);
  opacity: 0;
}

.quiz-verdict-overlay.show .quiz-verdict-stamp {
  animation: verdictStampIn 360ms var(--ease-out) 340ms forwards;
}

@keyframes verdictPopIn {
  0% {
    transform: translateY(24px) scale(0.84);
    opacity: 0;
  }
  72% {
    transform: translateY(-4px) scale(1.04);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@keyframes verdictStampIn {
  0% {
    transform: rotate(-10deg) scale(0.84);
    opacity: 0;
  }
  70% {
    transform: rotate(-6deg) scale(1.08);
    opacity: 1;
  }
  100% {
    transform: rotate(-7deg) scale(1);
    opacity: 1;
  }
}


.quiz-question {
  display: flex;
